# ===========================
# Application Configuration
# ===========================
PORT=8080
NODE_ENV=development

# ===========================
# Google Cloud / Gemini
# ===========================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# For local dev, use API key. In production, use ADC (Application Default Credentials).
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================
# PostgreSQL (Cloud SQL)
# ===========================
# Option A: Connection string (preferred for local/docker)
DATABASE_URL=postgres://election_user:election_pass@localhost:5432/election_education
# Option B: Individual params (used when DATABASE_URL is not set)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=election_education
DB_USER=election_user
DB_PASSWORD=election_pass
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===========================
# Redis (Memorystore)
# ===========================
# Option A: Connection URL (preferred for local/docker)
REDIS_URL=redis://localhost:6379
# Option B: Individual params
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# ===========================
# Kafka
# ===========================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=election-api
KAFKA_GROUP_ID=election-workers
KAFKA_TOPIC_QUERY_SUBMITTED=query.submitted
KAFKA_TOPIC_ANALYTICS=query.analytics
