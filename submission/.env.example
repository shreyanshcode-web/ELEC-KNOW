# ===========================
# Application Configuration
# ===========================
PORT=8080
NODE_ENV=development
# Set to 'false' to disable Kafka (app runs without event streaming)
KAFKA_ENABLED=true

# ===========================
# Google Cloud / Gemini
# ===========================
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_PROJECT_ID=your-gcp-project-id
# For local dev, use API key. In production, use ADC (Application Default Credentials).
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================
# PostgreSQL (Cloud SQL)
# ===========================
# Option A: Connection string (preferred for local/docker)
DATABASE_URL=postgres://election_user:election_pass@localhost:5432/election_education
# Option B: Individual params (used when DATABASE_URL is not set)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=election_education
DB_USER=election_user
DB_PASSWORD=election_pass
DB_POOL_MIN=2
DB_POOL_MAX=10
# Cloud Run only: Unix socket connection (set by Terraform)
# CLOUD_SQL_CONNECTION_NAME=project-id:region:election-db

# ===========================
# Redis (Memorystore)
# ===========================
# Option A: Connection URL (preferred for local/docker)
REDIS_URL=redis://localhost:6379
# Option B: Individual params
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600

# ===========================
# Kafka
# ===========================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=election-api
KAFKA_GROUP_ID=election-workers
KAFKA_TOPIC_QUERY_SUBMITTED=query.submitted
KAFKA_TOPIC_ANALYTICS=query.analytics

# ===========================
# Election Data APIs
# ===========================

# ECI Electoralsearch (no API key required — official ECI portal)
ECI_BASE_URL=https://electoralsearch.eci.gov.in

# data.gov.in Open Government Data Platform (free key: https://data.gov.in/)
DATAGOV_API_KEY=your_datagov_api_key_here
DATAGOV_BASE_URL=https://api.data.gov.in
# Resource UIDs (Lok Sabha 2024 — update for future elections)
DATAGOV_TURNOUT_RESOURCE=9a22a518-5a33-4bab-8d12-1a3c3e6f5c8e
DATAGOV_SCHEDULE_RESOURCE=9c3c4c8f-84ba-4ce8-b677-0c7edc8466fc
DATAGOV_RESULTS_RESOURCE=8d2daacf-937d-412f-94c0-bf9ab57e01c7

# Verifik Voting API (freemium — register at https://verifik.co)
VERIFIK_API_TOKEN=your_verifik_jwt_token_here
VERIFIK_BASE_URL=https://api.verifik.co
