{
  "name": "election-education-bot",
  "version": "2.0.0",
  "description": "An interactive election process education platform powered by Google Services with Kubernetes, Kafka, and Redis.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/workers/query.worker.js",
    "migrate": "node src/db/migrate.js",
    "deploy": "bash deploy.sh",
    "deploy:cloud-run": "node scripts/deploy-cloud-run.js",
    "deploy:cloudrun": "npm run deploy:cloud-run",
    "deploy:images": "bash deploy.sh --images-only",
    "deploy:k8s": "bash deploy.sh --deploy-only",
    "docker:up": "docker compose -f docker/docker-compose.yml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.6.0",
    "@google/genai": "^1.51.0",
    "axios": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.12.0",
    "redis": "^4.6.14"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^9.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
